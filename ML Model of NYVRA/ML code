def subsample(X, y, n=200_000, seed=42):
    """Returns a random subsample of size n (or full data if smaller)."""
    if len(y) <= n:
        return X, y
    rng = np.random.default_rng(seed)
    idx = rng.choice(len(y), size=n, replace=False)
    return X[idx], y[idx]

