import heapq

def dijkstra(graph, start, weight_key='distance'):
    dist = {n:float('inf') for n in graph}
    dist[start] = 0
    pred = {n:None for n in graph}
    pq = [(0,start)]
    while pq:
        d,u = heapq.heappop(pq)
        if d>dist[u]: continue
        for v,attrs in graph[u].items():
            w = attrs[weight_key]
            if dist[u]+w < dist[v]:
                dist[v]=dist[u]+w; pred[v]=u
                heapq.heappush(pq,(dist[v],v))
    return dist,pred

def _heuristic(u,v):
    return geodesic((G.nodes[u]['y'],G.nodes[u]['x']),
                    (G.nodes[v]['y'],G.nodes[v]['x'])).meters

def get_route(G, start_ll, end_ll, weight='length',
              avoid_nodes=None, hour=None, accessibility=False):
    """A* routing with optional avoid_nodes, time-aware cost, accessibility."""
    avoid_nodes = avoid_nodes or set()
    try:
        orig = ox.distance.nearest_nodes(G, start_ll[1], start_ll[0])
        dest = ox.distance.nearest_nodes(G, end_ll[1],   end_ll[0])
    except Exception as e:
        print(f"Node lookup failed: {e}"); return None,[],0,{0:0,1:0,2:0}

    def edge_w(u,v,data):
        if u in avoid_nodes or v in avoid_nodes: return float('inf')
        if accessibility and data.get('accessible',1)==0: return float('inf')
        if weight=='cost':
            base = data.get('cost', data.get('length',1))
            if hour is not None:
                night = (hour>=20 or hour<=5)
                base *= (1.3 if night and data.get('danger',0)>0 else 1.0)
            return base
        return data.get(weight, data.get('length',1))

    try:
        path = nx.astar_path(G, orig, dest, heuristic=_heuristic,
                              weight=lambda u,v,d: edge_w(u,v,d))
    except nx.NetworkXNoPath:
        print("No path found!"); return None,[],0,{0:0,1:0,2:0}

    colors,total,dcounts = [],0.0,{0:0,1:0,2:0}
    for i in range(len(path)-1):
        u,v = path[i],path[i+1]
        edges = G.get_edge_data(u,v)
        edge = min(edges.values(),key=lambda e:e.get(weight,e.get('length',1)))
        d = edge.get('danger',1)
        dcounts[d] = dcounts.get(d,0)+1
        colors.append(edge.get('color','gray'))
        total += edge.get('length',0)
    return path,colors,total,dcounts

def safety_score(dc):
    return max(0, 100 - dc.get(1,0)*5 - dc.get(2,0)*15)

