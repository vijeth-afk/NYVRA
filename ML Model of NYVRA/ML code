# ── Helper for early stopping with warm_start ──────────────────────────
def train_with_early_stop(model, X_train, y_train, X_val, y_val,
                          step=50, max_rounds=20, patience=5, verbose=True):
    """
    Trains a sklearn ensemble with warm_start, adding `step` trees each round.
    Stops if validation accuracy does not improve for `patience` rounds.
    Returns the final model, the best number of estimators, and the training history.
    """
    best_val = -1.0
    best_n = step
    no_improve = 0
    history = {"n_estimators": [], "train_acc": [], "val_acc": []}
    model.warm_start = True

    for rnd in range(1, max_rounds + 1):
        model.n_estimators = rnd * step
        model.fit(X_train, y_train)
        train_acc = accuracy_score(y_train, model.predict(X_train))
        val_acc   = accuracy_score(y_val,   model.predict(X_val))
        history["n_estimators"].append(model.n_estimators)
        history["train_acc"].append(train_acc)
        history["val_acc"].append(val_acc)

        if val_acc > best_val + 1e-5:
            best_val = val_acc
            best_n = model.n_estimators
            no_improve = 0
        else:
            no_improve += 1

        if verbose:
            print(f"  trees={model.n_estimators:>4d}  train={train_acc:.4f}  val={val_acc:.4f}"
                  + ("  <- best" if val_acc == best_val else f"  (no improvement {no_improve}/{patience})"))

        if no_improve >= patience:
            if verbose:
                print(f"  Early stop at {model.n_estimators} trees (best {best_n} trees, val={best_val:.4f})")
            break

    # Refit on full training data with best_n trees (disables warm_start to avoid side effects)
    model.set_params(n_estimators=best_n, warm_start=False)
    model.fit(X_train, y_train)
    return model, best_n, history

