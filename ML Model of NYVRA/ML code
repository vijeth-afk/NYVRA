_tdf['density_dist'] = _tdf['density_1km']*_tdf['dist_to_center_km']
_tdf['label'] = np.random.choice([0,1,2],600)
_tdf = pd.get_dummies(_tdf,columns=['cluster_id'],prefix='cluster')
_Xe = _tdf.drop(columns=['label']); _ye = _tdf['label']
_scE = StandardScaler(); _XeS = _scE.fit_transform(_Xe)
_xgb_e = XGBClassifier(eval_metric='mlogloss',random_state=42)
_lgb_e = LGBMClassifier(random_state=42,verbosity=-1)
_xgb_e.fit(_XeS,_ye); _lgb_e.fit(_XeS,_ye)

def _predict_edge(X_in):
    return np.round((_xgb_e.predict(X_in)+_lgb_e.predict(X_in))/2).astype(int)

def _edge_feat(pts):
    sdf = pd.DataFrame(pts,columns=['Latitude','Longitude'])
    sdf['dist_to_center_km'] = np.sqrt((sdf['Latitude']-center_lat)**2+
                                        (sdf['Longitude']-center_lon)**2)*111
    sr = np.radians(sdf[['Latitude','Longitude']].values)
    sdf['density_1km'] = _bt.query_radius(sr,r=_rad,count_only=True)-1
    sdf['cluster_id']  = _km.predict(sdf[['Latitude','Longitude']])
    sdf['density_dist'] = sdf['density_1km']*sdf['dist_to_center_km']
    sdf = pd.get_dummies(sdf,columns=['cluster_id'],prefix='cluster')
    for c in _Xe.columns:
        if c not in sdf.columns: sdf[c]=0
    return sdf[_Xe.columns]

