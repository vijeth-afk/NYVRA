# ── PyTorch Conv1D + LSTM hybrid ─────────────────────────────────
class SpatioTemporalNet(nn.Module):
    def __init__(self, n_features, seq_len, n_classes=3):
        super().__init__()
        self.conv1 = nn.Conv1d(n_features, 64, kernel_size=3, padding=1)
        self.bn1   = nn.BatchNorm1d(64)
        # For LSTM: input (N, T, C) — permute after conv
        self.lstm1 = nn.LSTM(64, 64, batch_first=True,
                             dropout=0.2, num_layers=2)
        self.drop  = nn.Dropout(0.2)
        self.fc1   = nn.Linear(64, 32)
        self.fc2   = nn.Linear(32, n_classes)

    def forward(self, x):           # x: (N, C, T)
        x = F.relu(self.bn1(self.conv1(x)))   # (N, 64, T)
        x = x.permute(0, 2, 1)               # (N, T, 64)
        x, _ = self.lstm1(x)                  # (N, T, 64)
        x = self.drop(x[:, -1, :])            # last time step
        x = F.relu(self.fc1(x))
        return self.fc2(x)

n_feat_st = len(ST_FEATURES)
