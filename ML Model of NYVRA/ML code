axes[0].set_xlabel('Episode'); axes[0].set_ylabel('Total Reward')
axes[0].grid(True, alpha=0.3)

axes[1].plot(smooth(episode_dangers), color='red')
axes[1].set_title('DQN Total Danger Accumulated (smoothed)')
axes[1].set_xlabel('Episode'); axes[1].set_ylabel('Danger sum')
axes[1].grid(True, alpha=0.3)
plt.suptitle('PyTorch Deep Q-Network Training', fontweight='bold')
plt.tight_layout(); plt.show()

