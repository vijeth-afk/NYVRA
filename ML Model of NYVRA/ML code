global_mean_risk = df['Risk_Score_raw'].mean()
K_BAYES = 5

# Bayesian smoothed area risk
df['area_risk_smooth'] = (area_n * area_mean + K_BAYES * global_mean_risk) / (area_n + K_BAYES)

# Step 2: Final risk = 30% individual + 70% area-level
df['Risk_Score'] = 0.30 * df['Risk_Score_raw'] + 0.70 * df['area_risk_smooth']
