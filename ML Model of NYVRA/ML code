print("🌳 Random Forest – early stopping:")
rf_model, rf_best_n, rf_hist = train_with_early_stop(
    rf_model, X_train_scaled, y_train_enc, X_val_scaled, y_val_enc,
    step=50, max_rounds=20, patience=5, verbose=True
)

y_pred_rf  = rf_model.predict(X_test_scaled)
