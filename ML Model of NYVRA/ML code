acc_rf_tr  = rf_model.score(X_train_scaled, y_train_enc)
acc_rf_val = rf_model.score(X_val_scaled, y_val_enc)
gap_rf     = acc_rf_tr - acc_rf
print(f"  Final → Train:{acc_rf_tr:.4f}  Val:{acc_rf_val:.4f}  Test:{acc_rf:.4f}  F1:{f1_rf:.4f}  Gap:{gap_rf:.4f}\n")

# ── 2. Extra Trees (warm_start + early stopping) ───────────────────────
et_model = ExtraTreesClassifier(
