# ─── CELL 20 · Deep Q-Network — PyTorch ────────────────────────────
import collections

GRID_SIZE    = 10
STATE_DIM    = GRID_SIZE * GRID_SIZE * 3
N_ACTIONS    = 4
GAMMA        = 0.95
EPSILON      = 1.0
EPSILON_MIN  = 0.05
EPSILON_DECAY= 0.995
LR_DQN       = 1e-3
BATCH_DQN    = 64
REPLAY_SIZE  = 5000
EPISODES     = 500

# ── Environment ──────────────────────────────────────────────────────
class SafeRouteEnv:
    def __init__(self, grid_size=GRID_SIZE):
        self.size   = grid_size
        self.danger = np.random.choice([0, 1, 2],
            size=(grid_size, grid_size), p=[0.5, 0.3, 0.2])
        self.start  = (0, 0)
        self.goal   = (grid_size-1, grid_size-1)

    def reset(self):
        self.pos   = list(self.start)
        self.steps = 0
        return self._state()

    def _state(self):
        s = np.zeros((self.size, self.size, 3), dtype=np.float32)
        s[self.pos[0],   self.pos[1],   0] = 1.0
        s[self.goal[0],  self.goal[1],  1] = 1.0
        s[:, :, 2] = self.danger / 2.0
        return s.flatten()

    def step(self, action):
        dr, dc = [(-1,0),(1,0),(0,-1),(0,1)][action]
        nr, nc  = self.pos[0]+dr, self.pos[1]+dc
        if 0 <= nr < self.size and 0 <= nc < self.size:
            self.pos = [nr, nc]
        d_pos   = self.danger[self.pos[0], self.pos[1]]
        reached = (self.pos[0] == self.goal[0] and self.pos[1] == self.goal[1])
        reward  = 10.0 if reached else (-0.1 - d_pos * 0.5)
        self.steps += 1
        done = reached or self.steps >= self.size * 4
        return self._state(), reward, done

# ── PyTorch DQN ──────────────────────────────────────────────────────
class DQNNet(nn.Module):
    def __init__(self):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(STATE_DIM, 128), nn.ReLU(),
            nn.LayerNorm(128),
            nn.Linear(128, 128), nn.ReLU(),
            nn.Linear(128, 64),  nn.ReLU(),
            nn.Linear(64,  N_ACTIONS),
        )
    def forward(self, x):
        return self.net(x)

dqn       = DQNNet().to(DEVICE)
target_q  = DQNNet().to(DEVICE)
target_q.load_state_dict(dqn.state_dict())
target_q.eval()

dqn_optim = TorchAdam(dqn.parameters(), lr=LR_DQN)
replay    = collections.deque(maxlen=REPLAY_SIZE)
env       = SafeRouteEnv()

def update_target():
    target_q.load_state_dict(dqn.state_dict())

def select_action(state, epsilon):
    if np.random.rand() < epsilon:
        return np.random.randint(N_ACTIONS)
    with torch.no_grad():
        st = torch.tensor(state, dtype=torch.float32).unsqueeze(0).to(DEVICE)
        return dqn(st).argmax().item()

def train_step():
    if len(replay) < BATCH_DQN:
        return
    batch  = random.sample(replay, BATCH_DQN)
    ss, aa, rr, nss, dd = map(np.array, zip(*batch))

    ss_t  = torch.tensor(ss,  dtype=torch.float32).to(DEVICE)
    nss_t = torch.tensor(nss, dtype=torch.float32).to(DEVICE)
    rr_t  = torch.tensor(rr,  dtype=torch.float32).to(DEVICE)
    dd_t  = torch.tensor(dd,  dtype=torch.float32).to(DEVICE)
    aa_t  = torch.tensor(aa,  dtype=torch.long).to(DEVICE)

    with torch.no_grad():
        next_q = target_q(nss_t).max(1)[0]
        targets = rr_t + GAMMA * (1 - dd_t) * next_q

    current_q = dqn(ss_t).gather(1, aa_t.unsqueeze(1)).squeeze(1)
    loss = F.smooth_l1_loss(current_q, targets)
    dqn_optim.zero_grad(); loss.backward(); dqn_optim.step()

episode_rewards, episode_dangers = [], []

for ep in range(EPISODES):
    state   = env.reset()
    total_r = 0.0; total_d = 0; done = False
    while not done:
        action  = select_action(state, EPSILON)
        ns, reward, done = env.step(action)
        danger_at = int(env.danger[env.pos[0], env.pos[1]])
        replay.append((state, action, reward, ns, float(done)))
        total_r += reward; total_d += danger_at; state = ns
        train_step()
    EPSILON = max(EPSILON_MIN, EPSILON * EPSILON_DECAY)
    episode_rewards.append(total_r)
    episode_dangers.append(total_d)
    if ep % 50 == 0:
        update_target()

print(f"✅ DQN training done  |  final ε={EPSILON:.4f}")

def smooth(arr, w=20):
    return pd.Series(arr).rolling(w, min_periods=1).mean().values

fig, axes = plt.subplots(1, 2, figsize=(14, 5))
axes[0].plot(smooth(episode_rewards), color='royalblue')
