def tree_early_stop_fit(model, X_tr, y_tr, X_val, y_val,
                        step=50, max_rounds=20, patience=5,
                        model_name="Model",
                        X_full=None, y_full=None):
    """
    Finds best n_estimators on (X_tr, y_tr), then re-fits on
    X_full / y_full if provided (= full training set).
    """
    best_val   = -1.0
    best_n     = step
    no_improve = 0
    history    = {"n_estimators": [], "val_acc": [], "train_acc": []}

    for rnd in range(1, max_rounds + 1):
        model.n_estimators = rnd * step
        model.fit(X_tr, y_tr)
        val_acc   = accuracy_score(y_val, model.predict(X_val))
        train_acc = accuracy_score(y_tr,  model.predict(X_tr))
        history["n_estimators"].append(model.n_estimators)
        history["val_acc"].append(val_acc)
        history["train_acc"].append(train_acc)

        if val_acc > best_val + 1e-5:
            best_val   = val_acc
            best_n     = model.n_estimators
            no_improve = 0
        else:
            no_improve += 1

        print(f"  [{model_name}] trees={model.n_estimators:>4d}  "
              f"train={train_acc:.4f}  val={val_acc:.4f}"
              + (" <- best" if no_improve == 0
                 else f"  (no improvement {no_improve}/{patience})"))

        if no_improve >= patience:
            print(f"  EARLY STOP @ {model.n_estimators} trees "
                  f"(best val={best_val:.4f} @ {best_n} trees)")
            break

    # ---- SPEEDUP: refit best config on FULL training data ----
    model.n_estimators = best_n
    if X_full is not None:
        model.warm_start = False          # plain fit on full data
        model.fit(X_full, y_full)
    else:
        model.fit(X_tr, y_tr)
    return model, best_n, history
