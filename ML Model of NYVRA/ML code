# Step 1: Bayesian area-level smoothing prevents zero-collapse
GRID_L = 0.008    # ~800 m grid cells
df['_glat'] = (df['Latitude']  / GRID_L).astype(int)
df['_glon'] = (df['Longitude'] / GRID_L).astype(int)
