# ── A) Spatial density at 3 radii (computed early — needed for fallback label) ─
coords_rad = np.radians(df[['Latitude','Longitude']].values)
ball_tree  = BallTree(coords_rad, metric='haversine')
for radius_km, col in [(0.5,'density_0p5km'),(1.0,'density_1km'),(2.0,'density_2km')]:
    df[col] = ball_tree.query_radius(coords_rad, r=radius_km/6371.0, count_only=True) - 1

df['log_density_0p5'] = np.log1p(df['density_0p5km'])
df['log_density_1']   = np.log1p(df['density_1km'])
df['log_density_2']   = np.log1p(df['density_2km'])

