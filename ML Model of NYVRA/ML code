# ── MULTI-STOP ROUTING ────────────────────────────────────
def multi_stop_route(G, waypoints, weight='cost'):
    """Plan route through multiple waypoints, minimising total danger."""
    full_path, all_colors, total_dist, total_danger = [],[],0,{0:0,1:0,2:0}
    for i in range(len(waypoints)-1):
        p,c,d,dc = get_route(G, waypoints[i], waypoints[i+1], weight)
        if p is None:
            print(f"No path: segment {i}→{i+1}"); return None,[],0,{}
        if full_path: full_path.extend(p[1:])
        else:         full_path.extend(p)
        all_colors.extend(c); total_dist+=d
        for k,v in dc.items(): total_danger[k]=total_danger.get(k,0)+v
    return full_path,all_colors,total_dist,total_danger

# ── ALTERNATIVE ROUTES (top 3) ────────────────────────────
def alternative_routes(G, start_ll, end_ll, n=3):
    """Return top-N routes ranked by safety/distance trade-off."""
    orig = ox.distance.nearest_nodes(G, start_ll[1], start_ll[0])
    dest = ox.distance.nearest_nodes(G, end_ll[1],   end_ll[0])
    routes = []
    try:
        gen = nx.shortest_simple_paths(G, orig, dest, weight='cost')
        for _,path in zip(range(n*3), gen):
            colors,total,dc = [],0.0,{0:0,1:0,2:0}
            for i in range(len(path)-1):
                e = G.get_edge_data(path[i],path[i+1])
                if e:
                    best = min(e.values(),key=lambda x:x.get('cost',x.get('length',1)))
                    d = best.get('danger',1)
                    dc[d]=dc.get(d,0)+1
                    colors.append(best.get('color','gray'))
                    total+=best.get('length',0)
            sc = safety_score(dc)
            dist_km = total/1000
            score = sc - dist_km*2
            routes.append({'path':path,'colors':colors,'dist_km':dist_km,
                           'safety':sc,'score':score,'danger':dc})
            if len(routes)>=n: break
    except Exception as ex:
        print(f"Alt routes error: {ex}")
        p,c,d,dc = get_route(G,start_ll,end_ll,weight='cost')
        if p: routes.append({'path':p,'colors':c,'dist_km':d/1000,
                              'safety':safety_score(dc),'score':0,'danger':dc})
    routes.sort(key=lambda r:-r['score'])
    return routes[:n]

# ── TURN-BY-TURN DIRECTIONS ───────────────────────────────
def turn_by_turn(G, path_nodes):
    """Generate text navigation instructions."""
    directions = []
    dirs_map = {(0,1):'Head East',(0,-1):'Head West',
                (1,0):'Head South',(-1,0):'Head North',
                (1,1):'Head South-East',(-1,1):'Head North-East',
                (1,-1):'Head South-West',(-1,-1):'Head North-West'}
    total_m = 0
    for i,node in enumerate(path_nodes):
        n_data = G.nodes[node]
        lat,lon = n_data['y'],n_data['x']
        if i==0:
            directions.append(f"🟢 START at ({lat:.4f},{lon:.4f})")
            continue
        prev = G.nodes[path_nodes[i-1]]
        dlat = 1 if lat>prev['y'] else (-1 if lat<prev['y'] else 0)
        dlon = 1 if lon>prev['x'] else (-1 if lon<prev['x'] else 0)
        txt  = dirs_map.get((dlat,dlon),f'Continue')
        edges = G.get_edge_data(path_nodes[i-1],node)
        if edges:
            edge = min(edges.values(),key=lambda e:e.get('length',1))
            seg_m = edge.get('length',0)
            total_m += seg_m
            danger = edge.get('danger',0)
            d_txt = ['🟢 Safe','🟡 Medium danger','🔴 High danger'][min(danger,2)]
            name = edge.get('name','unnamed road')
            directions.append(f"  {txt} on {name} for {seg_m:.0f}m — {d_txt}")
        if i==len(path_nodes)-1:
            directions.append(f"🏁 ARRIVE at ({lat:.4f},{lon:.4f})  "
                              f"Total: {total_m/1000:.2f}km")
    return directions

