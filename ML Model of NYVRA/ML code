# Safety alert function
def check_safety_alert(latlon, threshold=2.0):
    nearby = df[df.apply(
        lambda r: geodesic((r['Latitude'],r['Longitude']),latlon).km<1, axis=1)]
    if len(nearby)==0: return "✅ No data for this area."
    avg_d = nearby['danger_label'].mean()
    if avg_d >= threshold*0.67:
        return f"🚨 HIGH DANGER ALERT: avg danger={avg_d:.2f} within 1km of destination!"
    elif avg_d >= threshold*0.33:
        return f"⚠️  MEDIUM DANGER: avg danger={avg_d:.2f} within 1km."
    return f"✅ LOW DANGER area: avg danger={avg_d:.2f} within 1km."

