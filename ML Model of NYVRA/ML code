print("\n─── Bayesian Risk Modeling ───")
def bayesian_danger_estimate(lat,lon,df,radius_km=1.0,prior_alpha=1,prior_beta=1):
    nearby = df[df.apply(
        lambda r: geodesic((r['Latitude'],r['Longitude']),(lat,lon)).km<=radius_km,
        axis=1)]
    n       = len(nearby)
    n_high  = (nearby['danger_label']==2).sum()
    post_alpha = prior_alpha + n_high
    post_beta  = prior_beta  + (n - n_high)
    mean_p = post_alpha / (post_alpha+post_beta)
    var_p  = (post_alpha*post_beta) / ((post_alpha+post_beta)**2*(post_alpha+post_beta+1))
    ci_lo  = max(0, mean_p - 2*np.sqrt(var_p))
    ci_hi  = min(1, mean_p + 2*np.sqrt(var_p))
    return {'mean':mean_p,'ci_low':ci_lo,'ci_high':ci_hi,'n_obs':n}

