from sklearn.model_selection import StratifiedKFold
from sklearn.linear_model import LogisticRegression
from joblib import Parallel, delayed

def oof_proba(model, X, y, cv=3):  # 3 folds instead of 5
    """Out-of-fold probabilities for stacking — parallelized."""
    skf = StratifiedKFold(n_splits=cv, shuffle=True, random_state=42)
    n_classes = len(np.unique(y))
    splits = list(skf.split(X, y))

    params = model.get_params()
    if "early_stopping_rounds" in params:
        params = {**params, "early_stopping_rounds": None}

    # Force parallelism inside each base model
    if "n_jobs" in params:
        params = {**params, "n_jobs": -1}
    # Fewer trees for OOF clones — faster, still good signal
    if "n_estimators" in params:
        params = {**params, "n_estimators": min(params["n_estimators"], 100)}

    def fit_fold(ti, vi):
        m = type(model)(**params)
        m.fit(X[ti], y[ti])
        return vi, m.predict_proba(X[vi])

    # Parallel across folds
    results = Parallel(n_jobs=-1, prefer="threads")(
        delayed(fit_fold)(ti, vi) for ti, vi in splits
    )

    oof = np.zeros((len(X), n_classes))
    for vi, preds in results:
        oof[vi] = preds
    return oof

print("Computing OOF predictions...")
# Parallelize the 4 models concurrently
def compute_oof(args):
    model, X, y = args
    return oof_proba(model, X, y)

oof_rf, oof_xgb, oof_lgb, oof_et = Parallel(n_jobs=4, prefer="threads")(
    delayed(oof_proba)(m, X_train_scaled, y_train_enc)
    for m in [rf_model, xgb_model, lgb_model, et_model]
)

