    for xb, yb in st_loader:
        st_optim.zero_grad()
        out  = st_net(xb)
        loss = F.cross_entropy(out, yb)
        loss.backward(); st_optim.step()
        correct += (out.argmax(1) == yb).sum().item()
        total   += len(yb)
    tr_acc = correct / total

    st_net.eval()
    with torch.no_grad():
        val_out = st_net(X_st_te_t)
        val_loss = F.cross_entropy(val_out, y_st_te_t).item()
        val_acc  = (val_out.argmax(1) == y_st_te_t).float().mean().item()
    st_sched.step(val_loss)
    st_tr_acc_hist.append(tr_acc); st_va_acc_hist.append(val_acc)

