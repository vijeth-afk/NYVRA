def export_gpx(G, path_nodes, filename="route.gpx", name="Safe Route"):
    """Export a route as GPX for offline navigation."""
    if not GPX_OK:
        print("gpxpy not installed — pip install gpxpy"); return

    gpx = gpxpy.gpx.GPX()
    track = gpxpy.gpx.GPXTrack(name=name)
    gpx.tracks.append(track)
    segment = gpxpy.gpx.GPXTrackSegment()
    track.segments.append(segment)

    for node in path_nodes:
        lat = G.nodes[node]['y']
        lon = G.nodes[node]['x']
        segment.points.append(gpxpy.gpx.GPXTrackPoint(lat, lon))

    with open(filename,'w') as f:
        f.write(gpx.to_xml())
    print(f"✅ GPX saved → {filename}  ({len(path_nodes)} waypoints)")
    return filename

